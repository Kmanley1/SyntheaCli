# Keep the build context small and deterministic. The image only needs the
# source under src/ plus the root build props; everything below is noise or
# host-specific artifacts that would bust layer caching.
.git
.github
**/bin
**/obj
artifacts
TestResults
**/*.user
**/*.suo

# Not needed to publish the CLI
tests
JavaTestApp
docs
*.ps1
**/*.code-workspace
scorecard.json
